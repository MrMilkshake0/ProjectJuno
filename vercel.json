{
  "cleanUrls": true,

  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.projectjuno.ai" }],
      "destination": "https://projectjuno.ai/:path*",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "accept", "value": "text/html" }],
      "destination": "/index.html"
    }
  ]
}
